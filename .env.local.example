# All keys are SERVER-SIDE ONLY. Never expose to the client.
# Copy to .env.local and fill in.

ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: GitHub PR publishing
# Token needs `repo` scope (classic) or read+write contents + PRs (fine-grained).
GITHUB_TOKEN=
GITHUB_REPO=                # owner/repo
GITHUB_BASE_BRANCH=         # optional, defaults to the repo's default branch
GITHUB_PATH_PREFIX=         # optional, defaults to content/ghostfix

# LLM (one is enough; chain order: Anthropic → Groq → Gemini → templates).
# Free path: Groq. https://console.groq.com/keys — no card, real free tier.
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile  # uncomment to override

GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Optional
FIRECRAWL_API_KEY=
